# Solaris Dashboard — environment (ADR-OMK-001 / ADR-SUPABASE-001)
# Next.js env contract. Copy to .env.local and fill. NEVER commit real values
# (.gitignore covers .env*). The whole file is a template — do not paste real
# keys here, even temporarily, per the Test Key Pragma doctrine.
#
# In Next.js:
#   - NEXT_PUBLIC_* = exposed to the browser (build-time inlined)
#   - everything else = server-only (no public prefix)
# So the ANON key is public, the SERVICE_ROLE_KEY is server-only.

# --- Product mode: 'internal' (AaaS staff) | 'saas' (multi-tenant SMB clients) ---
NEXT_PUBLIC_APP_MODE="internal"

# --- Supabase self-hosted (VPS aspace-vps) ---
# URL of the self-hosted Supabase project (Caddy route or domain — confirm at deploy time).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# ANON key only (public). SERVICE_ROLE_KEY stays server-side, never here.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---
# SERVICE_ROLE_KEY bypasses RLS — it is the master key. Reserved for trusted
# server contexts (e.g. /api/webhooks, background jobs, /api/admin/*).
# Keep this commented in .env.example; set it in your real .env.local or in
# Dokploy environment variables at deploy time.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
